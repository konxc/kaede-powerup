{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "checkJs": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "verbatimModuleSyntax": false,
    "types": ["@types/bun"],
  },
  "include": ["packages/kaede-trello/src/**/*.ts", "src/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist", "dist-docs", "packages/mcp-server-trello", "public", "test"],
}
