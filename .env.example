# KAEDE MCP - Trello Credentials (EXAMPLE)
# 
# IMPORTANT: This is a REFERENCE file showing the required format.
# DO NOT copy this to your project folder!
#
# KAEDE uses GLOBAL credentials stored in:
#   - Windows: C:\Users\<You>\.config\kaede\secrets.env
#   - Linux/Mac: ~/.config/kaede/secrets.env
#
# Setup Methods:
#
# 1. RECOMMENDED: Use the setup wizard
#    node scripts/kaede.mjs setup
#
# 2. MANUAL: Create/edit the global secrets.env file
#    - Create directory: ~/.config/kaede/
#    - Create file: secrets.env
#    - Add your credentials (see below)
#
# Get your credentials from: https://trello.com/app-key
#   - API Key: Your application key (shown on page)
#   - Token: Click "Create a token" (Read & Write scope)

TRELLO_API_KEY=your_api_key_here
TRELLO_TOKEN=your_token_here

# Optional: Test board for development
TEST_BOARD_ID=rAKmlRj3
TEST_BOARD_URL=https://trello.com/b/rAKmlRj3/lab-testing-kaede
