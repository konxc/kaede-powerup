{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "instructions": [
    ".opencode/SHARED/project-context.md",
    ".opencode/SHARED/agent-rules.md",
    ".opencode/SHARED/instructions/orchestrator.md"
  ],
  "references": {
    "docs": {
      "path": "docs",
      "description": "Dokumentasi Power-Up, MCP, integrasi, role management"
    },
    "kaede": {
      "path": ".",
      "description": "KAEDE — Trello Power-Up & CLI tool untuk AI Agent ecosystem"
    },
    "playbook": {
      "path": "docs/playbook-template.md",
      "description": "Template playbook — SOP, workflow, standar. Ganti sesuai project."
    }
  },
  "agent": {
    "build": {
      "description": "Agent utama — maintain Power-Up, CLI, dokumentasi",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "ask"
      }
    },
    "plan": {
      "description": "Agent perencanaan — arsitektur, desain sebelum coding",
      "mode": "primary",
      "permission": {
        "edit": "deny"
      }
    }
  },
  "command": {
    "kaede-setup": {
      "description": "Setup Trello API Key & Token interaktif",
      "template": "bun scripts/kaede.mjs setup"
    },
    "kaede-today": {
      "description": "Tampilkan task Trello untuk hari ini",
      "template": "bun scripts/kaede.mjs today"
    },
    "kaede-status": {
      "description": "Cek status konfigurasi KAEDE",
      "template": "bun scripts/kaede.mjs status"
    },
    "kaede-init": {
      "description": "Inisialisasi KAEDE di project lain",
      "template": "bun scripts/kaede.mjs init $ARGUMENTS"
    },
    "dev": {
      "description": "Development server + CSS watch",
      "template": "bun run dev"
    },
    "build": {
      "description": "Build production CSS",
      "template": "bun run build"
    },
    "preview": {
      "description": "Preview build + serve",
      "template": "bun run preview"
    },
    "kaede-push": {
      "description": "Buat Trello cards dari file markdown (.md)",
      "template": "bun scripts/kaede.mjs push $ARGUMENTS"
    },
    "build-docs": {
      "description": "Build dokumentasi Markdown → HTML",
      "template": "bun scripts/build-docs.mjs"
    }
  },
  "mcp": {
    "kaede": {
      "type": "local",
      "command": ["bun", "dist/kaede-mcp-server.js"],
      "description": "Orchestrator — generate_plan, parse_playbook, bundle_context, status",
      "enabled": true,
      "timeout": 60000
    },
    "trello": {
      "type": "local",
      "command": ["bunx", "@delorenj/mcp-server-trello"],
      "description": "Eksekutor upstream — 45+ tools Trello resmi",
      "enabled": true,
      "timeout": 30000
    }
  }
}
