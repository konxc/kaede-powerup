# type(scope): subject (max 50 chars)
#
# type: feat | fix | refactor | chore | docs | test | style
# scope: mcp | trello | cli | api | auth | board | card | docs | deploy | config | test
#
# Examples:
#   feat(mcp): add attachment stubs with multipart upload
#   fix(cli): handle missing secrets.env gracefully
