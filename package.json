{
  "name": "kaede",
  "version": "1.0.0",
  "private": true,
  "description": "KAEDE — Trello Power-Up, MCP Server & CLI Orchestrator for AI Agent ecosystem",
  "type": "module",
  "scripts": {
    "dev": "bun run build:mcp && bun run dev:css & bun run serve",
    "dev:css": "tailwindcss -i src/style.css -o public/css/style.css --watch",
    "build": "tailwindcss -i src/style.css -o public/css/style.css --minify",
    "build:mcp": "node scripts/build-mcp.mjs",
    "serve": "bun x serve . -p 3000 -L",
    "preview": "bun run build && bun run serve",
    "kaede": "node scripts/kaede.mjs",
    "kaede:setup": "node scripts/kaede.mjs setup",
    "kaede:today": "node scripts/kaede.mjs today",
    "kaede:status": "node scripts/kaede.mjs status",
    "kaede:env": "node scripts/kaede.mjs env",
    "test": "node --test test/*.test.js",
    "test:orchestrator": "node --test test/orchestrator.test.js",
    "test:trello": "node --test test/trello-client.test.js",
    "test:e2e": "node --test test/e2e-orchestrator.test.js",
    "test:all": "node --test test/*.test.js"
  },
  "bin": {
    "kaede": "./scripts/kaede.mjs"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "netlify-cli": "^26.1.0",
    "tailwindcss": "^4.1.0"
  },
  "dependencies": {
    "marked": "^18.0.5"
  }
}
